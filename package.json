{
  "name": "role-based-ecommerce-admin",
  "version": "1.0.0",
  "description": "Role-based eCommerce admin dashboard using AdminJS, Sequelize, and PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/scripts/seed.js",
    "migrate": "sequelize-cli db:migrate --config sequelize.config.js",
    "migrate:undo": "sequelize-cli db:migrate:undo --config sequelize.config.js",
    "seed:cli": "sequelize-cli db:seed:all --config sequelize.config.js"
  },
  "keywords": [
    "adminjs",
    "express",
    "sequelize",
    "postgresql",
    "rbac"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@adminjs/express": "^5.1.0",
    "@adminjs/sequelize": "^3.0.0",
    "adminjs": "^6.8.7",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "sequelize-cli": "^6.6.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
